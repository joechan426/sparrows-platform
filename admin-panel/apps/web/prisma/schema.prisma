generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  USER
  MANAGER
  ADMIN
}

enum TournamentType {
  CUP
  LEAGUE
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users      Membership[]
  tournaments Tournament[]
  teams       Team[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  memberships Membership[]
}

model Membership {
  id        String @id @default(cuid())
  role      Role

  userId String
  orgId  String

  user User @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
}

model Tournament {
  id        String          @id @default(cuid())
  name      String
  type      TournamentType
  location  String?
  notes     String?

  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])

  createdAt DateTime @default(now())

  divisions     Division[]
  registrations TournamentRegistration[]
  matches       Match[]
}

model Division {
  id            String   @id @default(cuid())
  tournamentId  String
  name          String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  pools         Pool[]
  registrations TournamentRegistration[]
  matches       Match[]

  @@index([tournamentId])
}

model Pool {
  id         String   @id @default(cuid())
  divisionId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  division     Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  registrations TournamentRegistration[]
  matches      Match[]

  @@index([divisionId])
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model Team {
  id          String   @id @default(cuid())
  name        String
  captainId   String?
  createdAt   DateTime @default(now())

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])

  registrations TournamentRegistration[]
}

model TournamentRegistration {
  id            String   @id @default(cuid())
  status        RegistrationStatus @default(PENDING)
  createdAt     DateTime @default(now())

  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  divisionId    String
  division      Division @relation(fields: [divisionId], references: [id], onDelete: Restrict)

  poolId        String?
  pool          Pool?    @relation(fields: [poolId], references: [id], onDelete: SetNull)

  teamId        String
  team          Team @relation(fields: [teamId], references: [id])

  matchesAsTeamA Match[] @relation("MatchTeamA")
  matchesAsTeamB Match[] @relation("MatchTeamB")
  matchesAsDuty  Match[] @relation("MatchDuty")

  @@unique([tournamentId, teamId])
}

enum MatchStage {
  POOL
  KNOCKOUT
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model Match {
  id                  String      @id @default(cuid())
  tournamentId        String
  divisionId          String
  poolId              String?
  stage               MatchStage  @default(POOL)
  teamARegistrationId String
  teamBRegistrationId String
  dutyRegistrationId  String?
  seedA               Int?
  seedB               Int?
  courtName           String?
  scheduledAt         DateTime?
  status              MatchStatus @default(SCHEDULED)
  createdAt           DateTime    @default(now())

  tournament          Tournament             @relation(fields: [tournamentId], references: [id])
  division            Division               @relation(fields: [divisionId], references: [id])
  pool                Pool?                  @relation(fields: [poolId], references: [id])
  teamARegistration   TournamentRegistration @relation("MatchTeamA", fields: [teamARegistrationId], references: [id])
  teamBRegistration   TournamentRegistration @relation("MatchTeamB", fields: [teamBRegistrationId], references: [id])
  dutyRegistration    TournamentRegistration? @relation("MatchDuty", fields: [dutyRegistrationId], references: [id])
  sets                MatchSet[]

  @@index([tournamentId])
  @@index([divisionId])
  @@index([poolId])
}

model MatchSet {
  id         String @id @default(cuid())
  matchId    String
  setNumber  Int
  teamAScore Int
  teamBScore Int

  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model Member {
  id            String   @id @default(cuid())
  preferredName String
  email         String   @unique
  passwordHash  String?  // for email/password login
  appleId       String?  @unique // Sign in with Apple unique user id
  googleId      String?  @unique // Google Sign-In unique user id
  /// Stripe Customer id for saved cards / Checkout (platform account).
  stripeCustomerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations   EventRegistration[]
  paymentMethods  MemberPaymentMethod[]
}

/// Saved card metadata only (Stripe PaymentMethod ids). No PAN/CVC stored.
model MemberPaymentMethod {
  id                    String   @id @default(cuid())
  memberId              String
  stripePaymentMethodId String
  brand                 String?
  last4                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, stripePaymentMethodId])
  @@index([memberId])
  @@map("member_payment_methods")
}

enum CalendarEventSourceType {
  GOOGLE
  MANUAL
}

enum SportType {
  VOLLEYBALL
  PICKLEBALL
  TENNIS
}

enum CalendarEventType {
  NORMAL
  SPECIAL
}

model CalendarEvent {
  id                String              @id @default(cuid())
  sourceEventId     String
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime
  location          String?
  sourceType        CalendarEventSourceType
  sportType         SportType
  eventType         CalendarEventType
  registrationOpen  Boolean             @default(false)
  capacity          Int?
  /// Paid events require Stripe/PayPal checkout before registration is eligible for manager approval.
  isPaid            Boolean             @default(false)
  /// Price in minor units (e.g. AUD cents). API may expose `priceDollars` for forms.
  priceCents        Int?
  currency          String              @default("AUD")
  /// Named payment profile (Stripe Connect / PayPal REST app) that receives checkout for this event.
  paymentProfileId  String?             @map("payment_profile_id")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  registrations     EventRegistration[]
  paymentProfile    PaymentProfile?     @relation(fields: [paymentProfileId], references: [id], onDelete: SetNull)

  @@unique([sourceEventId, sourceType])
  @@index([paymentProfileId])
}

enum EventRegistrationStatus {
  PENDING
  APPROVED
  WAITING_LIST
  REJECTED
}

enum EventPaymentStatus {
  NONE
  AWAITING_PAYMENT
  PAID
  FAILED
  WAIVED
}

enum EventPaymentProvider {
  STRIPE
  PAYPAL
  MANUAL
}

model EventRegistration {
  id              String                  @id @default(cuid())
  memberId        String
  calendarEventId String
  teamName        String?
  status          EventRegistrationStatus @default(PENDING)
  paymentStatus   EventPaymentStatus      @default(NONE)
  amountDueCents  Int?
  amountPaidCents Int?
  paymentProvider EventPaymentProvider?
  stripeSessionId String?
  stripePaymentIntentId String?
  paypalOrderId   String?
  paidAt          DateTime?
  /// Manager adjustments to recorded amount (refunds handled outside the app).
  managerPaymentNote String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  member          Member        @relation(fields: [memberId], references: [id])
  event           CalendarEvent @relation(fields: [calendarEventId], references: [id])

  @@unique([memberId, calendarEventId])
}

/// Named payout configuration (Stripe Connect + optional PayPal REST credentials).
/// Created and linked by Super Managers / Admins; managers pick a profile when editing paid events.
model PaymentProfile {
  id                        String   @id @default(cuid())
  nickname                  String   @unique
  /// Inactive profiles are hidden from paid-event payment account pickers.
  isActive                  Boolean  @default(true) @map("is_active")
  stripeConnectedAccountId  String?  @unique @map("stripe_connected_account_id")
  stripeConnectChargesEnabled Boolean  @default(false) @map("stripe_connect_charges_enabled")
  paypalMerchantId          String?  @map("paypal_merchant_id")
  paypalRestClientIdEnc       String?  @map("paypal_rest_client_id_enc")
  paypalRestClientSecretEnc   String?  @map("paypal_rest_client_secret_enc")
  createdByAdminId          String?  @map("created_by_admin_id")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  createdBy    AdminUser?      @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  @@map("payment_profiles")
}

/// Singleton row id = "default". Toggles which checkout methods are offered platform-wide.
/// Paid event funds settle using the event's `PaymentProfile`.
model PaymentPlatformSettings {
  id             String   @id // always use "default" in application code
  stripeEnabled  Boolean  @default(false)
  paypalEnabled  Boolean  @default(false)
  squareEnabled  Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@map("payment_platform_settings")
}

// Admin panel users (separate from Member). Used for admin-panel login only.
enum AdminRole {
  ADMIN
  SUPER_MANAGER
  MANAGER
}

enum AdminModule {
  TOURNAMENTS
  TEAMS
  CALENDAR_EVENTS
  MEMBERS
  PAYMENT_PROFILES
  ADMIN_USERS
  PAYMENTS
}

model AdminUser {
  id                   String   @id @default(cuid())
  userName             String   @unique @map("user_name")
  email                String?  @unique
  passwordHash         String   @map("password_hash")
  role                 AdminRole
  isActive             Boolean  @default(true) @map("is_active")
  /// JSON array of resource names (e.g. "tournaments") this ADMIN hides from their own navigation only.
  hiddenNavResources   Json     @default("[]") @map("hidden_nav_resources")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  permissions AdminPermission[]
  paymentProfilesCreated PaymentProfile[]

  @@map("admin_users")
}

model AdminPermission {
  id         String      @id @default(cuid())
  adminUserId String     @map("admin_user_id")
  module     AdminModule
  createdAt  DateTime    @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, module])
  @@map("admin_permissions")
}