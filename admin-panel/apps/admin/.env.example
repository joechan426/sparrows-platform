# Optional: only set when the admin app is deployed on a different origin than the API (web app).
# Set to the full URL of the web site (no trailing slash), e.g. https://sparrows-web.netlify.app
# Leave unset for local dev (Vite proxy to localhost:3000) or when admin and web are same origin.
# VITE_API_URL=https://sparrows-web.netlify.app
